#!/bin/bash

################################################################################
# test-mcp-postgres: Complete testing workflow for mcp-postgres from registry
#
# This script:
# 1. Installs mcp-postgres from crates.io registry
# 2. Verifies PostgreSQL is running and accessible
# 3. Starts the server with HTTP/2 endpoint
# 4. Runs comprehensive tests:
#    - Health checks
#    - MCP compliance tests
#    - Tool functionality tests
#    - Performance/latency tests
# 5. Provides summary of all test results
#
# Usage: ./test-mcp-postgres [OPTIONS]
# Options:
#   --no-install     Skip installation, use existing binary
#   --verbose        Show detailed output
#   --quick          Run quick tests only
################################################################################

set -e

# Colors for output
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
REGISTRY_PACKAGE="mcp-postgres"
DB_URL="${DATABASE_URL:-postgres://piyush:@localhost:5432/postgres}"
HTTP_PORT=3001
TCP_PORT=3000
SERVER_HOST="127.0.0.1"
TEST_TIMEOUT=30

# Options
SKIP_INSTALL=false
VERBOSE=false
QUICK_ONLY=false

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --no-install) SKIP_INSTALL=true; shift ;;
        --verbose) VERBOSE=true; shift ;;
        --quick) QUICK_ONLY=true; shift ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
done

# Helper functions
log_info() {
    echo -e "${BLUE}ℹ${NC} $1"
}

log_success() {
    echo -e "${GREEN}✅${NC} $1"
}

log_error() {
    echo -e "${RED}❌${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}⚠${NC}  $1"
}

run_test() {
    local test_name="$1"
    local test_cmd="$2"

    log_info "Running: $test_name"
    if eval "$test_cmd"; then
        log_success "$test_name passed"
        return 0
    else
        log_error "$test_name failed"
        return 1
    fi
}

################################################################################
# Phase 1: Installation
################################################################################

echo -e "${BLUE}╔════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║${NC} PHASE 1: Installation from Registry              ${BLUE}║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════╝${NC}"

# Check for local build first (always prefer local for testing)
if [ -f "./target/release/mcp-postgres" ]; then
    MCP_BIN="./target/release/mcp-postgres"
    HTTP_AVAILABLE=true
    log_info "Using local development build with HTTP/2 support"
elif [ "$SKIP_INSTALL" = true ]; then
    log_error "Local build not found and --no-install flag set"
    exit 1
else
    log_info "Installing $REGISTRY_PACKAGE from crates.io..."
    if cargo install $REGISTRY_PACKAGE --force; then
        log_success "Package installed from registry"
        MCP_BIN="mcp-postgres"
        if mcp-postgres --help | grep -q "http-port"; then
            HTTP_AVAILABLE=true
            log_info "HTTP/2 endpoint available in installed binary"
        else
            HTTP_AVAILABLE=false
            log_warning "HTTP/2 endpoint not available in registry version, using TCP only"
        fi
    else
        log_error "Failed to install from registry"
        exit 1
    fi
fi

# Verify binary exists
if ! command -v mcp-postgres &> /dev/null; then
    log_error "mcp-postgres binary not found in PATH"
    exit 1
fi
log_success "mcp-postgres binary found: $(which mcp-postgres)"

################################################################################
# Phase 2: Prerequisite Checks
################################################################################

echo -e "\n${BLUE}╔════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║${NC} PHASE 2: Prerequisites & Cleanup                 ${BLUE}║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════╝${NC}"

# Kill any existing server
log_info "Cleaning up any existing processes..."
pkill -f "mcp-postgres --http-port" 2>/dev/null || true
sleep 1

# Check PostgreSQL connection
log_info "Verifying PostgreSQL connection..."
if psql -h localhost -U piyush -d postgres -c "SELECT 1" > /dev/null 2>&1; then
    log_success "PostgreSQL is running and accessible"
else
    log_error "Cannot connect to PostgreSQL at $DB_URL"
    echo "  Try: psql -h localhost -U piyush -d postgres -c 'SELECT 1'"
    exit 1
fi

################################################################################
# Phase 3: Start Server
################################################################################

echo -e "\n${BLUE}╔════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║${NC} PHASE 3: Starting Server                          ${BLUE}║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════╝${NC}"

if [ "$HTTP_AVAILABLE" = true ]; then
    log_info "Starting mcp-postgres server with HTTP/2 on port $HTTP_PORT..."
    DATABASE_URL="$DB_URL" $MCP_BIN --http-port $HTTP_PORT > /tmp/mcp-postgres.log 2>&1 &
    SERVER_PID=$!
    ENDPOINT_TYPE="HTTP/2"
else
    log_info "Starting mcp-postgres server with TCP on port $TCP_PORT..."
    DATABASE_URL="$DB_URL" $MCP_BIN -p $TCP_PORT > /tmp/mcp-postgres.log 2>&1 &
    SERVER_PID=$!
    ENDPOINT_TYPE="TCP"
fi

log_info "Server started with PID: $SERVER_PID"

# Wait for server to start
log_info "Waiting for server to be ready..."
for i in {1..30}; do
    if [ "$HTTP_AVAILABLE" = true ]; then
        CHECK_CMD="curl -s http://$SERVER_HOST:$HTTP_PORT/health > /dev/null 2>&1"
    else
        CHECK_CMD="echo 'test' | nc $SERVER_HOST $TCP_PORT > /dev/null 2>&1"
    fi

    if eval "$CHECK_CMD"; then
        log_success "Server is ready ($ENDPOINT_TYPE)"
        break
    fi
    if [ $i -eq 30 ]; then
        log_error "Server failed to start within 30 seconds"
        cat /tmp/mcp-postgres.log
        exit 1
    fi
    sleep 1
done

################################################################################
# Phase 4: Health Checks
################################################################################

echo -e "\n${BLUE}╔════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║${NC} PHASE 4: Health Checks                            ${BLUE}║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════╝${NC}"

# Test 1: Health endpoint (HTTP only)
if [ "$HTTP_AVAILABLE" = true ]; then
    HEALTH=$(curl -s http://$SERVER_HOST:$HTTP_PORT/health)
    if echo "$HEALTH" | jq -e '.status == "healthy"' > /dev/null 2>&1; then
        log_success "Health endpoint responding correctly"
        [ "$VERBOSE" = true ] && echo "  Response: $HEALTH"
    else
        log_error "Health endpoint returned unexpected response: $HEALTH"
        exit 1
    fi
else
    log_info "Skipping HTTP health check (TCP mode)"
fi

################################################################################
# Phase 5: MCP Compliance Tests
################################################################################

echo -e "\n${BLUE}╔════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║${NC} PHASE 5: MCP Compliance Tests                     ${BLUE}║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════╝${NC}"

# Helper function for requests
make_request() {
    local method="$1"
    local params="$2"

    if [ "$HTTP_AVAILABLE" = true ]; then
        # Build request JSON
        local request_json='{"jsonrpc":"2.0","method":"'"$method"'"'
        if [ -n "$params" ] && [ "$params" != "null" ]; then
            request_json="${request_json}"',"params":'"$params"
        fi
        request_json="${request_json}"',"id":1}'

        curl -s -X POST http://$SERVER_HOST:$HTTP_PORT/rpc \
            -H "Content-Type: application/json" \
            -d "$request_json"
    else
        # For TCP, construct proper JSON
        local request_json='{"jsonrpc":"2.0","method":"'"$method"'"'
        if [ -n "$params" ] && [ "$params" != "null" ]; then
            request_json="${request_json}"',"params":'"$params"
        fi
        request_json="${request_json}"',"id":1}'
        printf '%s\n' "$request_json" | nc -q 1 $SERVER_HOST $TCP_PORT 2>/dev/null | head -1
    fi
}

# Test 1: Initialize
log_info "Testing 'initialize' method..."
INIT=$(make_request "initialize" "{}")

if echo "$INIT" | jq -e '.result.protocolVersion and .result.capabilities and .result.serverInfo' > /dev/null 2>&1; then
    log_success "Initialize method returns correct format"
    [ "$VERBOSE" = true ] && echo "$INIT" | jq .
else
    log_error "Initialize method returned invalid format: $INIT"
    exit 1
fi

# Test 2: tools/list
log_info "Testing 'tools/list' method..."
TOOLS=$(make_request "tools/list" "null")

TOOL_COUNT=$(echo "$TOOLS" | jq '.result.tools | length' 2>/dev/null || echo "0")
if [ "$TOOL_COUNT" = "25" ]; then
    log_success "tools/list returns exactly 25 tools"
else
    log_error "tools/list returned $TOOL_COUNT tools (expected 25)"
    [ "$VERBOSE" = true ] && echo "Response: $TOOLS"
    exit 1
fi

# Test 3: tools/call - show_current_user
log_info "Testing 'tools/call' method (show_current_user)..."
CALL=$(make_request "tools/call" '{"name":"show_current_user","arguments":{}}')

if echo "$CALL" | jq -e '.result.user' > /dev/null 2>&1; then
    USER=$(echo "$CALL" | jq -r '.result.user')
    log_success "tools/call works (current user: $USER)"
else
    log_error "tools/call returned invalid response: $CALL"
    exit 1
fi

################################################################################
# Phase 6: Tool Functionality Tests
################################################################################

echo -e "\n${BLUE}╔════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║${NC} PHASE 6: Tool Functionality Tests                 ${BLUE}║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════╝${NC}"

# Test 1: list_tables
log_info "Testing 'list_tables' tool..."
TABLES=$(make_request "tools/call" '{"name":"list_tables","arguments":{}}')

if echo "$TABLES" | jq -e '.result.tables | type == "array"' > /dev/null 2>&1; then
    TABLE_COUNT=$(echo "$TABLES" | jq '.result.tables | length')
    log_success "list_tables returned $TABLE_COUNT tables"
else
    log_error "list_tables returned invalid format"
    [ "$VERBOSE" = true ] && echo "Response: $TABLES"
    exit 1
fi

# Test 2: execute_query
log_info "Testing 'execute_query' tool..."
QUERY=$(make_request "tools/call" '{"name":"execute_query","arguments":{"sql":"SELECT 1 as test"}}')

if echo "$QUERY" | jq -e '.result.rows | type == "array"' > /dev/null 2>&1; then
    log_success "execute_query works correctly"
else
    log_error "execute_query returned invalid format"
    [ "$VERBOSE" = true ] && echo "Response: $QUERY"
    exit 1
fi

# Test 3: Error handling
log_info "Testing error handling (invalid tool)..."
ERROR=$(make_request "tools/call" '{"name":"nonexistent_tool","arguments":{}}')

if echo "$ERROR" | jq -e '.error.code == -32601' > /dev/null 2>&1; then
    log_success "Error handling returns correct code (-32601)"
else
    log_error "Error handling returned unexpected response"
    [ "$VERBOSE" = true ] && echo "Response: $ERROR"
    exit 1
fi

################################################################################
# Phase 7: Performance Tests (Quick)
################################################################################

if [ "$QUICK_ONLY" = false ]; then
    echo -e "\n${BLUE}╔════════════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║${NC} PHASE 7: Performance Tests                        ${BLUE}║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════════════════╝${NC}"

    log_info "Running 10 sequential requests..."
    TOTAL_TIME=$(( $(date +%s%N) ))
    for i in {1..10}; do
        curl -s -X POST http://$SERVER_HOST:$HTTP_PORT/rpc \
            -H "Content-Type: application/json" \
            -d '{"jsonrpc":"2.0","method":"tools/call","params":{"name":"execute_query","arguments":{"sql":"SELECT '"$i"' as num"}},"id":1}' > /dev/null
    done
    TOTAL_TIME=$(( $(date +%s%N) - TOTAL_TIME ))
    AVG_MS=$(echo "scale=2; $TOTAL_TIME / 10000000" | bc)

    log_success "10 requests completed in ${AVG_MS}ms average"

    if (( $(echo "$AVG_MS < 10" | bc -l) )); then
        log_success "Performance is excellent (avg < 10ms)"
    elif (( $(echo "$AVG_MS < 50" | bc -l) )); then
        log_success "Performance is good (avg < 50ms)"
    else
        log_warning "Performance degraded (avg ${AVG_MS}ms)"
    fi
fi

################################################################################
# Phase 8: Summary & Cleanup
################################################################################

echo -e "\n${BLUE}╔════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║${NC} PHASE 8: Summary                                  ${BLUE}║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════╝${NC}"

log_success "All tests passed!"
echo ""
echo "📊 Test Summary:"
echo "  ✅ Installation from registry: Success"
echo "  ✅ Health checks: Success"
echo "  ✅ MCP compliance (initialize, tools/list, tools/call): Success"
echo "  ✅ Tool functionality (list_tables, execute_query, error handling): Success"
if [ "$QUICK_ONLY" = false ]; then
    echo "  ✅ Performance tests: Success"
fi
echo ""
echo "🚀 Server Information:"
echo "  Binary: $(which mcp-postgres)"
echo "  Version: $(mcp-postgres --version 2>/dev/null || echo 'N/A')"
echo "  HTTP/2 Port: $HTTP_PORT"
echo "  TCP Port: $TCP_PORT"
echo "  Database: $DB_URL"
echo ""
echo "📝 Server is running (PID: $SERVER_PID)"
echo "   Stop with: kill $SERVER_PID"
echo "   Logs: tail -f /tmp/mcp-postgres.log"
echo ""
echo "✨ Registry installation and testing complete!"

# Keep server running
trap "pkill -f 'mcp-postgres --http-port'; log_info 'Server stopped'" EXIT

# Interactive mode
echo ""
read -p "Press Enter to stop the server and exit, or Ctrl+C to keep it running..."
